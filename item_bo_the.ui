    border: 1px solid #cccccc; /* Viền màu xám nhạt */
}

/* Trạng thái khi chuột chạm lướt (Hover) */
QPushButton:hover {
    background-color: #f5f5f5; /* Nền chuyển sang xám cực nhạt */
    border: 1px solid #b3b3b3; /* Viền đậm lên một chút xíu */
}

