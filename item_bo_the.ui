       <property name="styleSheet">
        <string notr="true">/* Trạng thái mặc định */
QPushButton {
    background-color: #ffffff; /* Nền trắng */
    color: #444444;            /* Chữ màu xanh đen đậm */
    font-size: 15px;           /* Cỡ chữ */
    padding: 8px 25px;         /* Khoảng cách chữ đến viền */
    
    /* Bo góc và Viền */
    border-radius: 18px;       /* MẸO: Nhớ chỉnh số này bằng đúng 1/2 Chiều cao (Height) của nút nhé */
    border: 1px solid #cccccc; /* Viền màu xám nhạt */
}

/* Trạng thái khi chuột chạm lướt (Hover) */
QPushButton:hover {
    background-color: #f5f5f5; /* Nền chuyển sang xám cực nhạt */
    border: 1px solid #b3b3b3; /* Viền đậm lên một chút xíu */
}

/* Trạng thái khi click bấm giữ (Pressed) */
QPushButton:pressed {
    background-color: #e0e0e0; /* Nền xám rõ hơn khi bấm */
    border: 1px solid #999999;
}</string>
       </property>
       <property name="text">
