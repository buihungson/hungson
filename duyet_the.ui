         <property name="styleSheet">
          <string notr="true">/* 1. Trạng thái bình thường */
QLineEdit {
    background-color: #ffffff; /* Nền trắng */
    border: 1px solid #d1d5db; /* Viền xám nhạt */
    border-radius: 8px;        /* Bo góc nhẹ (không bo tròn vo như nút) */
