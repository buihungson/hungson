    font-size: 13px;           /* Cỡ chữ */
    color: #374151;            /* Chữ màu xám đen */
}

/* 2. Trạng thái khi chuột lướt qua (Hover) */
QLineEdit:hover {
    border: 1px solid #9ca3af; /* Viền đậm lên một chút xíu khi lướt qua */
}

/* 3. Trạng thái khi CLICK VÀO ĐỂ GÕ (Focus) - Cực kỳ quan trọng */
QLineEdit:focus {
    border: 2px solid #3b82f6; /* Viền chuyển sang màu xanh dương giống nút Lưu */
    background-color: #ffffff;
}</string>
