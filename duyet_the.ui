         <property name="styleSheet">
          <string notr="true">/* 1. Trạng thái bình thường */
QLineEdit {
    background-color: #ffffff; /* Nền trắng */
    border: 1px solid #d1d5db; /* Viền xám nhạt */
    border-radius: 8px;        /* Bo góc nhẹ (không bo tròn vo như nút) */
    padding: 6px 12px;         /* Khoảng cách chữ tới viền (TrênDưới TráiPhải) */
    font-size: 13px;           /* Cỡ chữ */
    color: #374151;            /* Chữ màu xám đen */
}

/* 2. Trạng thái khi chuột lướt qua (Hover) */
QLineEdit:hover {
    border: 1px solid #9ca3af; /* Viền đậm lên một chút xíu khi lướt qua */
}

/* 3. Trạng thái khi CLICK VÀO ĐỂ GÕ (Focus) - Cực kỳ quan trọng */
QLineEdit:focus {
    border: 2px solid #3b82f6; /* Viền chuyển sang màu xanh dương giống nút Lưu */
    background-color: #ffffff;
}</string>
         </property>
         <property name="placeholderText">
          <string>🔍 Tìm bộ thẻ...</string>
